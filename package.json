{
  "name": "whispering-lore",
  "version": "1.0.0",
  "private": true,
  "description": "A digital compendium of mythical creatures and folklore",
  "repository": {
    "type": "git",
    "url": "https://github.com/maf-ran/whispering-lore.git"
  },
  "license": "CC-BY-4.0",
  "author": "Mats Olsson <mafolsson@tutamail.com>",
  "homepage": "https://whisperinglore.com",
  "keywords": [
    "mythology",
    "folklore",
    "mythical-creatures",
    "legends",
    "digital-humanities"
  ],
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "text-summary"],
    "collectCoverageFrom": [
      "js/shared-utils.js",
      "js/citations.js",
      "js/region-glyphs.js",
      "js/rune-scatter.js",
      "js/daily-feature.js",
      "js/quiz.js",
      "js/mylore.js",
      "js/viewer-base.js",
      "archive/lib/questionFactory.js"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "eslint": "^8.0.0",
    "fake-indexeddb": "^6.2.5",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^2.8.0",
    "serve": "^14.2.0",
    "wait-on": "^7.0.0"
  }
}
